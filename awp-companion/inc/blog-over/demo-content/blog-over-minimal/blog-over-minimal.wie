{"sidebar-1":{"block-2":{"content":"<!-- wp:search \/-->"},"block-3":{"content":"<!-- wp:group --><div class=\"wp-block-group\"><!-- wp:heading --><h2>Recent Posts<\/h2><!-- \/wp:heading --><!-- wp:latest-posts \/--><\/div><!-- \/wp:group -->"},"block-4":{"content":"<!-- wp:group --><div class=\"wp-block-group\"><!-- wp:heading --><h2>Recent Comments<\/h2><!-- \/wp:heading --><!-- wp:latest-comments {\"displayAvatar\":false,\"displayDate\":false,\"displayExcerpt\":false} \/--><\/div><!-- \/wp:group -->"},"block-5":{"content":"<!-- wp:group --><div class=\"wp-block-group\"><!-- wp:heading --><h2>Archives<\/h2><!-- \/wp:heading --><!-- wp:archives \/--><\/div><!-- \/wp:group -->"},"block-6":{"content":"<!-- wp:group --><div class=\"wp-block-group\"><!-- wp:heading --><h2>Categories<\/h2><!-- \/wp:heading --><!-- wp:categories \/--><\/div><!-- \/wp:group -->"}},"footer-1":{"block-9":{"content":"<!-- wp:heading -->\n<h2 class=\"wp-block-heading\">About Us<\/h2>\n<!-- \/wp:heading -->"},"block-10":{"content":"<!-- wp:details -->\n<details class=\"wp-block-details\"><summary>Where powerful ideas meet thoughtful storytelling, delivering meaningful insights, practical knowledge, and fresh perspectives that cut through digital noise.<\/summary><!-- wp:paragraph {\"placeholder\":\"Type \/ to add a hidden block\"} -->\n<p><\/p>\n<!-- \/wp:paragraph --><\/details>\n<!-- \/wp:details -->"},"block-13":{"content":"<!-- wp:columns {\"verticalAlignment\":\"bottom\"} -->\n<div class=\"wp-block-columns are-vertically-aligned-bottom\"><!-- wp:column {\"verticalAlignment\":\"bottom\",\"width\":\"100%\"} -->\n<div class=\"wp-block-column is-vertically-aligned-bottom\" style=\"flex-basis:100%\"><!-- wp:group {\"layout\":{\"type\":\"constrained\"}} -->\n<div class=\"wp-block-group\"><!-- wp:search {\"label\":\"Search\",\"buttonText\":\"Search\"} \/--><\/div>\n<!-- \/wp:group --><\/div>\n<!-- \/wp:column --><\/div>\n<!-- \/wp:columns -->"}},"footer-2":{"block-16":{"content":"<!-- wp:heading -->\n<h2 class=\"wp-block-heading\">Gallery<\/h2>\n<!-- \/wp:heading -->"},"block-15":{"content":"<!-- wp:gallery {\"columns\":4,\"linkTo\":\"none\",\"sizeSlug\":\"full\"} -->\n<figure class=\"wp-block-gallery has-nested-images columns-4 is-cropped\"><!-- wp:image {\"id\":28,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"https:\/\/awplife.com\/demo\/blog-over-dark\/wp-content\/uploads\/sites\/163\/2026\/03\/img-9.jpg\" alt=\"\" class=\"wp-image-28\"\/><\/figure>\n<!-- \/wp:image -->\n\n<!-- wp:image {\"id\":23,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"https:\/\/awplife.com\/demo\/blog-over-dark\/wp-content\/uploads\/sites\/163\/2026\/03\/img-6.jpg\" alt=\"\" class=\"wp-image-23\"\/><\/figure>\n<!-- \/wp:image -->\n\n<!-- wp:image {\"id\":22,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"https:\/\/awplife.com\/demo\/blog-over-dark\/wp-content\/uploads\/sites\/163\/2026\/03\/img-10.jpg\" alt=\"\" class=\"wp-image-22\"\/><\/figure>\n<!-- \/wp:image -->\n\n<!-- wp:image {\"id\":19,\"sizeSlug\":\"full\",\"linkDestination\":\"none\",\"className\":\"is-style-rounded\"} -->\n<figure class=\"wp-block-image size-full is-style-rounded\"><img src=\"https:\/\/awplife.com\/demo\/blog-over-dark\/wp-content\/uploads\/sites\/163\/2026\/03\/img-7.jpg\" alt=\"\" class=\"wp-image-19\"\/><\/figure>\n<!-- \/wp:image -->\n\n<!-- wp:image {\"id\":31,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"https:\/\/awplife.com\/demo\/blog-over-dark\/wp-content\/uploads\/sites\/163\/2026\/03\/img-4.jpg\" alt=\"\" class=\"wp-image-31\"\/><\/figure>\n<!-- \/wp:image -->\n\n<!-- wp:image {\"id\":16,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"https:\/\/awplife.com\/demo\/blog-over-dark\/wp-content\/uploads\/sites\/163\/2026\/03\/img-3.jpg\" alt=\"\" class=\"wp-image-16\"\/><\/figure>\n<!-- \/wp:image -->\n\n<!-- wp:image {\"id\":37,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"https:\/\/awplife.com\/demo\/blog-over-dark\/wp-content\/uploads\/sites\/163\/2026\/03\/img-8.jpg\" alt=\"\" class=\"wp-image-37\"\/><\/figure>\n<!-- \/wp:image -->\n\n<!-- wp:image {\"id\":34,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"https:\/\/awplife.com\/demo\/blog-over-dark\/wp-content\/uploads\/sites\/163\/2026\/03\/img-5.jpg\" alt=\"\" class=\"wp-image-34\"\/><\/figure>\n<!-- \/wp:image -->\n\n<!-- wp:image {\"id\":13,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"https:\/\/awplife.com\/demo\/blog-over-dark\/wp-content\/uploads\/sites\/163\/2026\/03\/img-1.jpg\" alt=\"\" class=\"wp-image-13\"\/><\/figure>\n<!-- \/wp:image -->\n\n<!-- wp:image {\"id\":10,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"https:\/\/awplife.com\/demo\/blog-over-dark\/wp-content\/uploads\/sites\/163\/2026\/03\/img-2.jpg\" alt=\"This Is How Minimal Will Look Like\" class=\"wp-image-10\"\/><\/figure>\n<!-- \/wp:image --><\/figure>\n<!-- \/wp:gallery -->"}},"footer-3":{"block-18":{"content":"<!-- wp:heading -->\n<h2 class=\"wp-block-heading\">Latest Post<\/h2>\n<!-- \/wp:heading -->"},"block-17":{"content":"<!-- wp:latest-posts \/-->"},"block-19":{"content":"<!-- wp:categories {\"displayAsDropdown\":true,\"showPostCounts\":true} \/-->"}}}